# 环境
NODE_ENV=development
PORT=3000

# 数据库
DATABASE_URL="postgresql://nestjs_user:nestjs_pass@localhost:5432/enterprise_platform?schema=public"

# Redis
REDIS_URL="redis://:redis_pass@localhost:6379"

# JWT
JWT_SECRET=change-this-to-a-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# 日志
LOG_LEVEL=debug

# CORS
CORS_ORIGIN=http://localhost:3001

# Rate Limit
THROTTLE_TTL=60000
THROTTLE_LIMIT=20
