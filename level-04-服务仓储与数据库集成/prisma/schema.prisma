// WHAT: Prisma Schema——数据库模型的唯一真相源
//
// 【核心原理——Prisma vs TypeORM 选择】
//   Prisma 优势：
//   - Schema-first: 先定义 schema，自动生成类型安全的 Client
//   - 类型安全: 生成的类型比 TypeORM 更精确（包括关联查询）
//   - 迁移: prisma migrate 自动生成 SQL 迁移文件
//   - 不依赖 reflect-metadata（TypeORM 依赖装饰器，与 NestJS 深度耦合）
//
//   TypeORM 优势：
//   - 更接近 Spring Data JPA 的风格（@Entity/@Column 装饰器）
//   - Repository Pattern 更自然
//   - 支持 Active Record 模式
//
// 【对比 Spring JPA + Hibernate】
//   两者都是 ORM，但思路不同：
//   - Spring JPA: Entity 类定义在 Java 中，数据库表由 Hibernate DDL 创建
//   - Prisma: Schema 是独立的 DSL，Client 是生成的——"Schema-First"
//   效果类似，但 Prisma 的 Schema 更紧凑，且生成代码更类型安全。
//
// 【对比 Django ORM】
//   Django ORM: Model 定义在 Python 中，与 Django 深度绑定
//   Prisma: 独立的 Schema 语言，不依赖任何框架——可以在 Express/Fastify 中使用

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ======================================
// Cat 模型——演示基础 CRUD + 软删除 + 审计字段
// ======================================
model Cat {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(50)
  age       Int
  breed     String   @db.VarChar(30)

  // WHAT: 软删除字段——标记记录是否被"删除"
  // WHY: 商业应用中几乎不会物理删除——需要保留审计追踪、支持数据恢复
  // 【对比 TypeORM】TypeORM 用 @DeleteDateColumn() 装饰器 + SoftDelete
  // 【对比 Spring JPA】@SQLDelete + @Where 注解
  deletedAt DateTime?

  // WHAT: 审计字段——自动记录创建/更新时间
  // WHY: Prisma 不自动处理（与 TypeORM 的 @CreateDateColumn/@UpdateDateColumn 不同）
  //   需要在应用层或数据库触发器设置
  // 【对比 Spring JPA】@CreatedDate/@LastModifiedDate + @EnableJpaAuditing
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cats")
}

// ======================================
// User 模型——演示关联关系（一对多）
// ======================================
model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(50)
  email     String   @unique @db.VarChar(100)
  role      Role     @default(USER)

  // WHAT: 一对多关系：一个 User 拥有多个 Cat
  // WHY: Prisma 的关系定义在 Schema 中，生成的类型包含嵌套关联
  cats      CatOnUser[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ======================================
// 多对多关联表：User <-> Cat
// ======================================
// WHAT: 显式定义关联表（而不是 Prisma 隐式多对多）
// WHY: 显式关联表可以存储额外字段（如 ownershipDate）
//   如果不需要额外字段，Prisma 支持隐式多对多（省略中间表定义）
model CatOnUser {
  cat             Cat    @relation(fields: [catId], references: [id], onDelete: Cascade)
  catId           Int
  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          Int
  ownershipDate   DateTime @default(now())

  @@id([catId, userId])
  @@map("cat_on_users")
}

// ======================================
// 枚举
// ======================================
enum Role {
  ADMIN
  USER
  VIEWER
}
