# ============================================================
# NestJS 学习项目 - 环境变量模板
# 复制此文件为 .env 并修改实际值
# cp .env.example .env
# ============================================================

# 应用端口
PORT=3000

# PostgreSQL 连接字符串（对应 docker-compose.yml 中的配置）
# 格式：postgresql://用户名:密码@主机:端口/数据库名?schema=public
DATABASE_URL="postgresql://nestjs_user:nestjs_pass@localhost:5432/nestjs_learn?schema=public"

# JWT 配置
JWT_SECRET="your-super-secret-key-change-in-production"
JWT_EXPIRATION="7d"
JWT_REFRESH_EXPIRATION="30d"

# 环境标识
NODE_ENV=development

# CORS 允许的前端地址（Vue3 开发服务器）
CORS_ORIGIN=http://localhost:5173

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
